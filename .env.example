OPENAI_API_KEY=your-token-here
# Optional: use an OpenAI-compatible endpoint (local proxy, self-hosted, etc.)
# OPENAI_BASE_URL=https://your-api-endpoint.com

# Optional: Google Workspace CLI MCP integration (gws)
# Select OAuth account profile created with gws auth login/list
# GOOGLE_WORKSPACE_CLI_ACCOUNT=default
# Comma-separated services exposed via gws MCP (default: gmail,calendar,drive)
# GWS_MCP_SERVICES=gmail,calendar,drive
# Set to 0 to disable gws MCP server
# NANOCLAW_ENABLE_GWS_MCP=1
# Optional: host path to gws config dir (default: ~/.config/gws)
# GWS_CONFIG_DIR=~/.config/gws

# Added by skill
DISCORD_BOT_TOKEN=
